{
  "name": "darkfactory-templates",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev:cli": "bun --filter @template/cli run dev",
    "dev:web": "bun --filter @template/web run dev",
    "start": "bun --filter @template/web run start",
    "sync:submodules": "git submodule update --init --recursive",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^5.8.3"
  }
}
