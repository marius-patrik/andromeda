{
  "name": "@marius-patrik/agent-os",
  "version": "0.1.0",
  "description": "Agent OS workspace with a Bun TypeScript agent package manager and shared CLI state.",
  "type": "module",
  "bin": {
    "agents": "./packages/agent-package-manager/src/cli.ts"
  },
  "scripts": {
    "check": "bunx tsc --noEmit",
    "test": "bun test packages/agent-package-manager/test/gitmodules.test.ts packages/agent-package-manager/test/adapters.test.ts packages/agent-package-manager/test/packages.test.ts packages/agent-package-manager/test/harness-cli.test.ts",
    "ci": "bun run check && bun run test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT"
}
