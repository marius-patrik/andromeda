{
  "schemaVersion": 1,
  "providers": [
    {
      "id": "kimi",
      "enabled": true,
      "secret": "KIMI_AUTH_JSON",
      "install": {
        "method": "npm",
        "package": "@moonshot-ai/kimi-code",
        "version": "latest"
      },
      "models": {
        "default": "kimi-code/kimi-for-coding",
        "byTaskClass": {
          "mechanical": "kimi-code/kimi-for-coding",
          "standard": "kimi-code/kimi-for-coding",
          "hard": "kimi-code/kimi-for-coding"
        }
      },
      "maxConcurrency": 2
    },
    {
      "id": "codex",
      "enabled": true,
      "secret": "CODEX_AUTH_JSON",
      "models": {
        "default": "gpt-5.5",
        "byTaskClass": {
          "mechanical": "gpt-5.5",
          "standard": "gpt-5.5",
          "hard": "gpt-5.5"
        }
      },
      "maxConcurrency": 1,
      "dockerImage": "darkfactory-codex-worker"
    },
    {
      "id": "agy",
      "enabled": false,
      "secret": "AGY_AUTH_JSON",
      "models": {
        "default": "agy-default"
      },
      "maxConcurrency": 1
    }
  ]
}
