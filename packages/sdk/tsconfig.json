{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@agent-os/shared-ts": ["shared-ts/src/index.ts"],
      "@agent-os/shared-ts/gen": ["shared-ts/src/gen/index.ts"],
      "@agent-os/web": ["../web/src/index.ts"]
    }
  },
  "include": [
    "tests/**/*.ts"
  ]
}
